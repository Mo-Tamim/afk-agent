#!/usr/bin/env bash
# `afk` — single entrypoint for the orchestrator.
#
# This is a thin dispatcher. Subcommands live in sibling .sh files; the only
# logic here is help text and the `status` / `stop-notify` shortcuts that
# don't deserve their own script.
#
# Subcommands:
#   afk setup                     — create labels, sanity-check tools
#   afk decompose <PRD>           — explode one PRD issue into children
#   afk run [--once] [--prd N]    — start the parallel orchestrator
#   afk issue <N>                 — drive ONE child issue end-to-end
#   afk document                  — kick the docs gate manually
#   afk status                    — print state of every in-flight issue
#   afk stop-notify               — silence any active notify-developer alarm
#
# Override defaults via env or config.yml (see .afk/config.yml).

set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib/common.sh
. "$SCRIPT_DIR/lib/common.sh"
. "$SCRIPT_DIR/lib/state.sh"

cmd="${1:-help}"
shift || true

case "$cmd" in
  # --- pass-through subcommands ------------------------------------------
  # Each one is a separate script so it can be invoked directly too (handy
  # for debugging without going through the dispatcher).
  setup)         "$SCRIPT_DIR/ensure-setup.sh"   "$@" ;;
  decompose)     "$SCRIPT_DIR/decompose.sh"      "$@" ;;
  run)           "$SCRIPT_DIR/orchestrate.sh"    "$@" ;;
  issue)         "$SCRIPT_DIR/run-issue.sh"      "$@" ;;
  document)      "$SCRIPT_DIR/document-gate.sh"  "$@" ;;

  # --- inline subcommands (no dedicated script) --------------------------
  status)
    # Snapshot every in-flight issue's progress. Computed entirely from the
    # state files — no tracker calls — so it's safe to spam in chat.
    if ls "$AFK_STATE"/issue-*.json >/dev/null 2>&1; then
      # Keep the phase order in sync with .afk/config.yml::phases. The
      # `resume_at` column is derived as "first phase not in completed_phases".
      PHASE_ORDER=(plan implement review pr pr_review merge)
      ORDER_JSON="$(printf '%s\n' "${PHASE_ORDER[@]}" | jq -R . | jq -s .)"
      for f in "$AFK_STATE"/issue-*.json; do
        jq -r --argjson order "$ORDER_JSON" '
          . as $s
          | ((($order - (.completed_phases // []))[0]) // "(all done)") as $next
          | (((.completed_phases // []) | join(",")) | if . == "" then "—" else . end) as $done
          | "#\($s.issue) [\($s.status // "?")] done=\($done) | resume_at=\($next) | branch=\($s.branch // "—") | pr=\($s.pr // "—") | updated=\($s.updated_at)"
        ' "$f"
      done
    else
      echo "(no state files)"
    fi
    ;;

  stop-notify)
    # Idempotent — no-op if no alarm script is installed.
    afk::notify_stop
    echo "stopped any running notification alarms"
    ;;

  # --- help / unknown ----------------------------------------------------
  help|--help|-h|"")
    # Print the header comment block (lines 2..18) verbatim, stripping the
    # leading '# '. Keeps usage docs in one place.
    sed -n '2,18p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//'
    ;;
  *)
    afk::die "unknown command: $cmd  (try: afk help)"
    ;;
esac
